{
  "_meta": {
    "description": "Full platform deep-dive UAT — every module and screen on zorbit-uat.onezippy.ai",
    "updated": "2026-04-15"
  },
  "baseUrl": "https://zorbit-uat.onezippy.ai",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 20000,
    "waitAfterAction": 700,
    "waitForNetworkIdle": false
  },

  "segments": {

    "api-health-all-services": {
      "name": "API Health — All 16 Services",
      "description": "Health check every deployed service via nginx proxy",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Starting platform-wide API health checks" }
        },
        { "action": "wait", "timeout": 1000 },
        {
          "action": "apiCheck",
          "endpoint": "/api/identity/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Identity", "after": "Identity: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/authorization/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Authorization", "after": "Authorization: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/navigation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Navigation", "after": "Navigation: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/messaging/api/v1/G/messaging/health",
          "expectedStatus": [200],
          "announce": { "before": "Messaging", "after": "Messaging: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pii_vault/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "PII Vault", "after": "PII Vault: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/audit/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Audit", "after": "Audit: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/pcg4/api/v1/G/health",
          "expectedStatus": [200, 404],
          "announce": { "before": "PCG4", "after": "PCG4: responded" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/white_label/api/v1/G/white_label/health",
          "expectedStatus": [200],
          "announce": { "before": "White Label", "after": "White Label: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/zmb_factory/api/v1/G/zmb_factory/health",
          "expectedStatus": [200],
          "announce": { "before": "ZMB Factory", "after": "ZMB Factory: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/hi_quotation/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "HI Quotation", "after": "HI Quotation: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/hi_uw_decisioning/api/v1/G/hi_uw_decisioning/health",
          "expectedStatus": [200],
          "announce": { "before": "HI UW Decisioning", "after": "HI UW Decisioning: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/uw_workflow/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "UW Workflow", "after": "UW Workflow: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/product_pricing/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Product Pricing", "after": "Product Pricing: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/form_builder/api/v1/G/form_builder/health",
          "expectedStatus": [200],
          "announce": { "before": "Form Builder", "after": "Form Builder: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/datatable/api/v1/G/datatable/health",
          "expectedStatus": [200],
          "announce": { "before": "DataTable", "after": "DataTable: healthy" }
        },
        {
          "action": "apiCheck",
          "endpoint": "/api/doc_generator/api/v1/G/health",
          "expectedStatus": [200],
          "announce": { "before": "Doc Generator", "after": "Doc Generator: healthy" }
        },
        {
          "action": "screenshot",
          "value": "uat-00-api-health-all.png",
          "announce": { "after": "All 16 service health checks complete" }
        }
      ]
    },

    "login-flow": {
      "name": "Login",
      "description": "Authenticate as admin and verify dashboard loads",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "Navigating to login page" }
        },
        { "action": "wait", "timeout": 1500 },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "timeout": 10000
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login submitted" }
        },
        { "action": "wait", "timeout": 4000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation'], main",
          "timeout": 20000,
          "announce": { "after": "Dashboard loaded. Authenticated." }
        },
        {
          "action": "screenshot",
          "value": "uat-01-login.png"
        }
      ]
    },

