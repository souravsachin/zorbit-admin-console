{
  "_meta": {
    "description": "TruUptime — read-only deep regression across every screen and API endpoint on zorbit-uat.onezippy.ai",
    "updated": "2026-04-15"
  },
  "baseUrl": "https://zorbit-uat.onezippy.ai",
  "viewport": { "width": 1440, "height": 900 },
  "defaults": {
    "timeout": 20000,
    "waitAfterAction": 700,
    "waitForNetworkIdle": false
  },

  "segments": {

    "seg-login": {
      "name": "Login",
      "description": "Navigate to login page, authenticate, verify dashboard loads",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "announce": { "before": "TruUptime: navigating to login page" }
        },
        { "action": "wait", "timeout": 1500 },
        {
          "action": "screenshot",
          "value": "tru-00-login-page.png"
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "timeout": 10000
        },
        {
          "action": "fill",
          "selector": "input[type='email'], input[name='email'], input[placeholder*='email' i]",
          "value": "${credentials.admin.email}"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "${credentials.admin.password}"
        },
        {
          "action": "click",
          "selector": "button[type='submit'], button:has-text('Sign in'), button:has-text('Login')",
          "announce": { "after": "Login submitted" }
        },
        { "action": "wait", "timeout": 4000 },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation'], main",
          "timeout": 20000,
          "announce": { "after": "Dashboard loaded. Authenticated." }
        },
        {
          "action": "screenshot",
          "value": "tru-01-logged-in.png"
        }
      ]
    },

    "seg-dashboard": {
      "name": "Dashboard",
      "description": "Verify dashboard loads with sidebar and user info",
      "steps": [
        {
          "action": "navigate",
          "url": "/app/dashboard",
          "announce": { "before": "Dashboard" }
        },
        { "action": "wait", "timeout": 2500 },
        {
          "action": "assertVisible",
          "selector": "main, [class*='dashboard'], [class*='content']",
          "timeout": 12000
        },
        {
          "action": "assertVisible",
          "selector": "nav, aside, [class*='sidebar'], [role='navigation']",
          "timeout": 5000,
          "announce": { "after": "Sidebar menu visible" }
        },
        {
          "action": "screenshot",
          "value": "tru-02-dashboard.png"
        }
      ]
    },

