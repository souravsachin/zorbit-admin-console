{
  "baseUrl": "https://zorbit-uat.onezippy.ai",
  "credentials": {
    "admin": {
      "email": "s@onezippy.ai",
      "password": "s@2021#cz"
    }
  },
  "viewport": {
    "width": 1440,
    "height": 900
  },
  "defaults": {
    "timeout": 15000,
    "waitAfterAction": 2000,
    "waitForNetworkIdle": false
  },
  "segments": {
    "login": {
      "name": "Login + Pin Sidebar",
      "description": "TU-LG: Login and pin sidebar open for all subsequent navigation",
      "steps": [
        {
          "action": "navigate",
          "url": "/login",
          "description": "TU-LG01: Open login page"
        },
        {
          "action": "screenshot",
          "value": "tru-LG01-login-page.png"
        },
        {
          "action": "assertVisible",
          "selector": "input[type='email']",
          "description": "TU-LG02: Email field present"
        },
        {
          "action": "fill",
          "selector": "input[type='email']",
          "value": "s@onezippy.ai",
          "description": "TU-LG02: Enter email"
        },
        {
          "action": "fill",
          "selector": "input[type='password']",
          "value": "s@2021#cz",
          "description": "TU-LG03: Enter password"
        },
        {
          "action": "screenshot",
          "value": "tru-LG03-credentials-entered.png"
        },
        {
          "action": "click",
          "selector": "button[type='submit']",
          "description": "TU-LG04: Click Sign In"
        },
        {
          "action": "wait",
          "timeout": 4000,
          "description": "Wait for login redirect"
        },
        {
          "action": "assertVisible",
          "selector": "text=Sourav Sachin",
          "description": "TU-LG05: User name visible after login"
        },
        {
          "action": "screenshot",
          "value": "tru-LG05-logged-in.png"
        },
        {
          "action": "click",
          "selector": "button[title='Toggle sidebar']",
          "description": "TU-DB02: Open hamburger menu"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "click",
          "selector": "button[title='Unlock sidebar (drawer mode)']",
          "optional": true,
          "description": "TU-DB02: Workaround click 1 \u2014 unpin phantom state"
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "click",
          "selector": "button[title='Lock sidebar open']",
          "optional": true,
          "description": "TU-DB02: Workaround click 2 \u2014 actually pin"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "screenshot",
          "value": "tru-DB02-sidebar-pinned.png"
        }
      ]
    },
