        { "action": "wait", "timeout": 800 },
        { "action": "fill", "selector": "[data-testid='role-name'], form input.input-field >> nth=0", "value": "Rules Manager ${runId}" },
        { "action": "fill", "selector": "[data-testid='role-description'], form input.input-field >> nth=1", "value": "Configure STP rules and automation" },
        { "action": "click", "selector": "[data-testid='role-create-submit'], form button[type='submit']" },
