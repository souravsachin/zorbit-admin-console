        {
          "action": "javascript",
          "value": "(async()=>{const r=await fetch('/api/identity/api/v1/G/auth/login',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:'${credentials.underwriter.email}',password:await(async()=>{const e=new TextEncoder();const h=await crypto.subtle.digest('SHA-256',e.encode('${credentials.underwriter.password}'));return Array.from(new Uint8Array(h)).map(b=>b.toString(16).padStart(2,'0')).join('')})()})}); const d=await r.json(); if(d.accessToken){localStorage.setItem('zorbit_token',d.accessToken);localStorage.setItem('zorbit_user',JSON.stringify({token:d.accessToken,refreshToken:d.refreshToken}));}})()"
