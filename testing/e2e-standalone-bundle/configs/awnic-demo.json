        { "action": "wait", "timeout": 300 },

        { "action": "click", "selector": "[data-testid='role-create-btn'], button:has-text('Create Role')" },
        { "action": "wait", "timeout": 800 },
        { "action": "fill", "selector": "[data-testid='role-name'], form input.input-field >> nth=0", "value": "Pricing Analyst ${runId}" },
        { "action": "fill", "selector": "[data-testid='role-description'], form input.input-field >> nth=1", "value": "Manage rate tables and premiums" },
        { "action": "click", "selector": "[data-testid='role-create-submit'], form button[type='submit']" },
