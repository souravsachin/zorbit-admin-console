    "pcg4-new": {
      "name": "PCG4: Start New Config",
      "steps": [
        { "action": "navigate", "url": "/app/pcg4/configurations" },
        { "action": "wait", "timeout": 2000 },
        { "action": "assertVisible", "selector": "h1:has-text('Product Configurator')", "timeout": 10000 },
        { "action": "screenshot", "value": "pcg4-01-dashboard.png" },
        { "action": "click", "selector": "[data-testid='pcg4-new-config'], button:has-text('New Configuration')" },
        { "action": "wait", "timeout": 2500 },
        { "action": "assertVisible", "selector": "h2:has-text('Insurer Details')", "timeout": 10000 }
      ]
    },

    "pcg4-step1": {
      "name": "PCG4 Step 1: Insurer Details",
      "steps": [
        { "action": "fill", "selector": "[data-testid='pcg4-insurer-name'], input[placeholder*='Healthy Life Insurance']", "value": "Al Wathba National Insurance ${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-insurer-code'], input[placeholder*='HLI001']", "value": "AWNIC-${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-regulator-code'], input[placeholder*='REG-HLI']", "value": "REG-AWNIC-${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-insurer-description'], textarea[placeholder*='description']", "value": "Al Wathba National Insurance Company — leading UAE insurer since 1996." },
        { "action": "screenshot", "value": "pcg4-02-step1.png" },
        { "action": "click", "selector": "[data-testid='pcg4-step1-next'], button:has-text('Next: Product Details')" },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step2": {
      "name": "PCG4 Step 2: Product Details",
      "steps": [
        { "action": "assertVisible", "selector": "h2:has-text('Product Details')", "timeout": 10000 },
        { "action": "fill", "selector": "[data-testid='pcg4-product-name'], input[placeholder*='Comprehensive Health Plus']", "value": "NAS Health Shield ${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-product-code'], input[placeholder*='CHP-2024']", "value": "NAS-${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-product-regulator-code'], input[placeholder*='REG-PROD']", "value": "REG-NAS-${runId}" },
        { "action": "fill", "selector": "[data-testid='pcg4-product-description'], textarea[placeholder*='Describe']", "value": "NAS health insurance — DHA/DOH compliant. Gold and Silver tiers." },
        { "action": "screenshot", "value": "pcg4-03-step2.png" },
        { "action": "click", "selector": "[data-testid='pcg4-step2-next'], button:has-text('Next: Create Plans')" },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step3": {
      "name": "PCG4 Step 3: Create Plans",
      "steps": [
        { "action": "assertVisible", "selector": "h2:has-text('Create Plans')", "timeout": 10000 },
        { "action": "fill", "selector": "[data-testid='pcg4-plan-name-0'], input[placeholder*='Health Plus Gold']", "value": "NAS Gold ${runId}" },
        { "action": "select", "selector": "[data-testid='pcg4-plan-tier-0'], select >> nth=0", "value": "Gold" },
        { "action": "click", "selector": "label:has-text('Middle East')" },
        { "action": "click", "selector": "[data-testid='pcg4-add-plan'], button:has-text('Add Another Plan')" },
        { "action": "wait", "timeout": 1000 },
        { "action": "fill", "selector": "[data-testid='pcg4-plan-name-1'], input[placeholder*='Health Plus Gold'] >> nth=1", "value": "NAS Silver ${runId}" },
        { "action": "select", "selector": "[data-testid='pcg4-plan-tier-1'], select >> nth=2", "value": "Silver" },
        { "action": "click", "selector": "label:has-text('Middle East') >> nth=1" },
        { "action": "screenshot", "value": "pcg4-04-step3.png" },
        { "action": "click", "selector": "[data-testid='pcg4-step3-next'], button:has-text('Next: Base')" },
        { "action": "wait", "timeout": 2000 }
      ]
    },

    "pcg4-step4": {
      "name": "PCG4 Step 4: Base Config",
      "steps": [
        { "action": "assertVisible", "selector": "h2:has-text('Base Plan Configuration')", "timeout": 10000 },
        { "action": "fill", "selector": "input[type='number'] >> nth=0", "value": "1000000" },
        { "action": "fill", "selector": "input[type='number'] >> nth=1", "value": "500" },
