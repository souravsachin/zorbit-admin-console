    "create-org": {
      "name": "Create AWNIC Organization",
      "steps": [
        { "action": "navigate", "url": "/organizations" },
        { "action": "wait", "timeout": 2000 },
        { "action": "assertVisible", "selector": "h1:has-text('Organizations')", "timeout": 10000 },
        { "action": "click", "selector": "[data-testid='org-create-btn'], button:has-text('Create Organization')" },
        { "action": "wait", "timeout": 1000 },
        { "action": "fill", "selector": "[data-testid='org-name'], form input.input-field", "value": "Al Wathba National Insurance ${runId}" },
        { "action": "select", "selector": "[data-testid='org-type'], form select.input-field", "value": "Insurance Company" },
        { "action": "screenshot", "value": "01-org-form.png" },
        { "action": "click", "selector": "[data-testid='org-create-submit'], form button[type='submit']" },
        { "action": "wait", "timeout": 3000 },
        { "action": "screenshot", "value": "02-org-created.png" }
      ]
    },

