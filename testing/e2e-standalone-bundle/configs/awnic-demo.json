        { "action": "wait", "timeout": 1500 },
        { "action": "pressEscape" },
        { "action": "wait", "timeout": 300 },

        { "action": "click", "selector": "[data-testid='role-create-btn'], button:has-text('Create Role')" },
        { "action": "wait", "timeout": 800 },
        { "action": "fill", "selector": "[data-testid='role-name'], form input.input-field >> nth=0", "value": "Underwriter ${runId}" },
        { "action": "fill", "selector": "[data-testid='role-description'], form input.input-field >> nth=1", "value": "Review and approve quotations" },
